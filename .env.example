# Telegram bot token
TELEGRAM_TOKEN=your_bot_token_here

# Telegram chat/user ID to send signals to
CHAT_ID=your_chat_id_here

# Minimum pump % to trigger a signal (default 11.0)
MIN_PUMP_PCT=11.0

# Scan interval in seconds (default 30)
SCAN_INTERVAL=30

# Minimum 24h quote volume in USDT to filter low-liquidity pairs (default 1000000)
MIN_VOLUME_USDT=1000000
